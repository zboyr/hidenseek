\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Detection accuracy across all 10 runs. Left: per-run accuracy with mean and 95\% CI. Right: accuracy distribution with normal fit. The mean accuracy of 60.7\% is significantly above the 10\% random baseline ($t(9)=13.41$, $p < 0.001$).}}{1}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:accuracy_dist}{{1}{1}{Detection accuracy across all 10 runs. Left: per-run accuracy with mean and 95\% CI. Right: accuracy distribution with normal fit. The mean accuracy of 60.7\% is significantly above the 10\% random baseline ($t(9)=13.41$, $p < 0.001$)}{figure.caption.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Per-trial detection accuracy averaged over 9 runs with full data. Blue bars show average accuracy at each trial position; the red curve shows cumulative accuracy from trial 5 onward. Error bars indicate standard error.}}{1}{figure.caption.2}\protected@file@percent }
\newlabel{fig:learning_curve}{{2}{1}{Per-trial detection accuracy averaged over 9 runs with full data. Blue bars show average accuracy at each trial position; the red curve shows cumulative accuracy from trial 5 onward. Error bars indicate standard error}{figure.caption.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Detection rate for each paraphraser when randomly selected as the duplicate source. GPT-5-Nano is detected with 100\% accuracy, while Llama-3.1-8B is hardest to detect at 25\%.}}{1}{figure.caption.3}\protected@file@percent }
\newlabel{fig:detection_rate}{{3}{1}{Detection rate for each paraphraser when randomly selected as the duplicate source. GPT-5-Nano is detected with 100\% accuracy, while Llama-3.1-8B is hardest to detect at 25\%}{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Aggregated confusion matrix showing how often the Detective paired each combination of paraphrasers. Diagonal entries represent correct identifications. The strong GPT-5-Nano--DIPPER off-diagonal (32) indicates the Detective frequently confuses these two.}}{2}{figure.caption.4}\protected@file@percent }
\newlabel{fig:confusion}{{4}{2}{Aggregated confusion matrix showing how often the Detective paired each combination of paraphrasers. Diagonal entries represent correct identifications. The strong GPT-5-Nano--DIPPER off-diagonal (32) indicates the Detective frequently confuses these two}{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Response length (word count) distributions per paraphraser. Left: box plots. Right: overlaid histograms. Llama-3.1-8B produces the longest outputs ($\mu =104$), while DIPPER produces the shortest ($\mu =75$).}}{2}{figure.caption.5}\protected@file@percent }
\newlabel{fig:response_length}{{5}{2}{Response length (word count) distributions per paraphraser. Left: box plots. Right: overlaid histograms. Llama-3.1-8B produces the longest outputs ($\mu =104$), while DIPPER produces the shortest ($\mu =75$)}{figure.caption.5}{}}
